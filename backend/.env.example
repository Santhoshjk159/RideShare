# Backend Environment Variables for Railway Production
# Add these variables in Railway dashboard under your backend service

# Server Configuration
NODE_ENV=production
PORT=3000

# Database Configuration (Railway MySQL)
# Get these values from your Railway MySQL service Variables tab
DB_HOST=containers-us-west-xxx.railway.app
DB_PORT=6543
DB_USER=root
DB_PASSWORD=your-railway-mysql-password
DB_NAME=railway

# JWT Configuration (Generate secure random strings)
JWT_SECRET=your-super-secure-jwt-secret-key-at-least-64-characters-long
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-key-at-least-64-characters-long

# CORS Configuration (Update with your Railway frontend URL)
FRONTEND_URL=https://your-frontend-service.up.railway.app

# Optional: Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
